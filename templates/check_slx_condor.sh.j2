#!/bin/bash

# Configuration
dmsetup="/dev/mapper/scratch * type=1
/dev/mapper/tank * type=1
/dev/mapper/root / type=1"
disk_setup=0
timeout_sec={{ nfs_check_timeout_sec }}
SCRATCH_MOUNT=/scratch

# 1. Check DMSetup
if [ "$(cat /run/openslx/dmsetup.state | grep -v "#" | cut -d, -f 1)" = "$dmsetup" ]; then
    disk_setup=1
fi

# 2. Check for OPENSLX_SYS partition label
openslx_label=0
if timeout $timeout_sec blkid | grep -qs "OPENSLX_SYS"; then
    openslx_label=1
fi

# 3. Run df and check status
df_out="$(timeout "$timeout_sec" df 2>/dev/null)"
df_rc=$?

# 4. Check scratch mount
scratch=0
if [ "$disk_setup" -eq 1 ] && echo "$df_out" | grep -qs "$SCRATCH_MOUNT"; then
    scratch=1
fi

# 5. Determine NFS health (0 = Bad, 1 = Good)
# We map your "2" (working) to "True" and anything else to "False" for Condor booleans
if [ "$df_rc" -eq 0 ]; then
    nfs_available="True"
else
    nfs_available="False"
fi

# --- HTCondor ClassAd Output ---
# Every line must be Attribute = Value
echo "SLX_DiskSetupOk = $disk_setup"
echo "SLX_ScratchMounted = $scratch"
echo "SLX_LabelPresent = $openslx_label"
echo "NFS_Available = $nfs_available"
